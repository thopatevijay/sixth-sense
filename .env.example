# Copy to .env and fill in. NEVER commit .env (it is gitignored).

# --- TxLINE / Solana auth (scripts/txline-auth.mjs) ---
TX_NET=devnet                       # devnet (60s delay) | mainnet (real-time SL 12)
TX_KEYPAIR_PATH=~/.config/solana/id.json
# SOLANA_RPC=                       # optional RPC override
# JWT + API token are written to .txline-session.json by `npm run auth` (gitignored)

# --- Relay (standalone Node SSE service; not on Vercel) ---
RELAY_PORT=8787
RELAY_DEFAULT_MODE=replay           # live | replay | mock  (deployed default: replay)
CORS_ORIGIN=*                       # set to the app origin in production
# TX_SESSION_PATH=.txline-session.json

# --- Privy (invisible Solana wallet, gasless) ---
PRIVY_APP_ID=
PRIVY_APP_SECRET=
NEXT_PUBLIC_PRIVY_APP_ID=

# --- Helius (Solana RPC + DAS for reading cNFTs) ---
HELIUS_API_KEY=
HELIUS_RPC_URL=

# --- On-chain Moment (Metaplex Bubblegum cNFT) ---
FEE_PAYER_KEYPAIR=                  # path to gasless fee-payer keypair
BUBBLEGUM_TREE_ADDRESS=

# --- Data ---
DATABASE_URL=

# --- App → relay wiring (Next.js client) ---
NEXT_PUBLIC_RELAY_URL=http://localhost:8787
